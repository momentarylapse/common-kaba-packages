	func extern is_undoable() -> bool
	func extern is_redoable() -> bool
	func extern mut undo()
	func extern mut redo()
	func extern mut set_cursor_pos(pos: i32, selecting = false)
	func extern mut replace_range(i0: i32, i1: i32, by: string)

	struct extern Markup
		var i0, i1: i32
		var flags: FontFlags
		var color: Color
	func extern mut clean_markup(i0: i32, i1: i32)
	func extern mut add_markup(m: Markup)
	struct extern LinePos
		var line: i32
		var offset: i32
