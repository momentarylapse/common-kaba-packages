	func get_partition() -> Tick[]
		if log_scale
#			if freq_as_pitch
#				return get_pitch_partition()
			return get_log_partition()
		return get_lin_partition()


func _get_ticks(range: Range, total_pixels: f32, spacing0: f32, logscale: bool) -> Tick[]
	var r: Tick[]
	let d0 = len(range) / total_pixels * spacing0

	let ld0 = log(d0) / log(10.0)
	var ldi = i32(ld0 + 0.5)
	if ld0 < 0
		ldi = i32(ld0 - 0.5)
	let d = pow(10.0, ldi)

	let x0 = (i32(range.min / d) - 1) * d

	for x in x0:range.max:d
		r.add([x, 1.0, "{{x|0.1}}"])

	return r
