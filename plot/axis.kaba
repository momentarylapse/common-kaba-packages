

struct Range
	var min, max: f32
	func length() -> f32
		return max - min


func get_range(x: f32[]) -> Range
	return [min(x), max(x)]


struct Tick
	value: f32
	weight: f32
	label: string


struct Axis
	var range: Range
	var val_min_min, val_max_max: f32? # zoom limit
	var log_scale = false
	var unit = ""
	var offset = 0.0
	var size = 100.0 # "pixels"
	var min_label_dist = 50.0

	func project(x: f32) -> f32
		if log_scale
			return offset + (log(x) - log(range.min)) / (log(range.max) - log(range.min)) * size
		return offset + (x - range.min) / len(range) * size

	func get_lin_partition() -> Tick[]
		let d = abs(len(range) / size) * 150 # ideal step
		var r: Tick[]
		let e = floor(log(d) / log(10))
		let step = pow(10.0, e) # quantized step
		let factor = d / step
		let decimals = i32(max(-e, 0))
		let min = floor(range.min / step) * step
		let max = range.max

		var vv = min
		var i = i32(floor(range.min / step))
		while vv <= max and step > 0
			var w = 0.4
			if (i % 10) == 0
				w = 1.0
			r.add([vv, w, "{{vv.str2(decimals)}} {{unit}}"])
			if factor < 3
				r.add([vv + step / 2, 0.2, ""])
			vv += step
			i ++

		return r

	func get_log_partition() -> Tick[]
		let pixel_per_decade = abs(size / log(range.max / range.min)) * log(10)
		let size_param = pixel_per_decade / min_label_dist
		var r: Tick[]
		let e_min = int(log(abs(range.min)) / log(10))
		let e_max = int(log(abs(range.max)) / log(10)) + 1
		for e in e_min:e_max
			var vv0 = pow(10, e)
			for i in 1:10
				var vv = vv0 * i
				if (vv >= range.min) and (vv <= range.max)
					var label: string
					var show = false
					if (i == 1)
						show = true
					if (i == 3) and (size_param > 2)
						show = true
					if ((i == 2) or (i == 5)) and (size_param > 4)
						show = true
					if show
						label = "{{vv|.0}} {{unit}}"
					r.add([vv, exp(-(i+1)*0.07), label])
				vv = vv0 * 1.5
				if (i == 1) and (vv >= range.min) and (vv <= range.max)
					r.add([vv, 0.2, ""])
		return r

