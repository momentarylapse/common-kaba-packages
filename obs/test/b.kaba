use obs


class A extends Object as obs.Node
	var source = obs.XPSource(&self, &ind, "source")


class B extends Object as obs.Node
	var sink: obs.XPSink
	func override __init__()
		sink.__init0__(&self, func(p: void&) print("hi!  {{p2s(p)}}"))


func main()
	var a: A
	var b: B
	obs.xpsubscribe(a.source, b.sink)
	print(p2s(&a))
	a.source._notify(&a)

