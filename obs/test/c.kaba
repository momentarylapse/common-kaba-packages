use obs


class A extends Object
	var ind: obs.InternalNodeData
	var source = obs.XSource[string](&self, &ind, "source")


class B extends Object
	var ind: obs.InternalNodeData
	var sink: obs.XSink[string]
	func override __init__()
		sink.__init2__(&self, func(s: string) print("hi!  {{s}}"))


func main()
	var a: A
	var b: B
	obs.xsubscribe[string](a.source, b.sink)
	a.source.notify("test")

