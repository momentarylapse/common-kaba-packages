use polymesh.*
use .common.*

func main()
	let mesh0 = create_cube(Box.ID_SYM, [1,1,1])

	var edits: MeshEdit[]
	var inv: MeshEdit[]
	var invinv: MeshEdit[]

	var mesh = mesh0
	for i in 0:15
		let sel = mesh_select_random_polygons(mesh, i)
		let ed = extrude_polygons(mesh, sel, 0.1, false)
		edits.add(ed)
		inv.add(ed.apply_inplace(mesh))
		check_mesh_health(mesh)

	for i in reversed(inv)
		invinv.add(i.apply_inplace(mesh))
		check_mesh_health(mesh)

	assert_equal(mesh, mesh0)

#	FIXME inversion...
#	show_mesh_diff(edits[0]);
#	show_mesh_diff(inv.back());
#	show_mesh_diff(invinv.back());

	for ii in reversed(invinv)
		ii.apply_inplace(mesh)
		check_mesh_health(mesh)