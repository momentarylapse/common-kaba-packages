func optimize(x: f32[], f: f32[]->f32) -> f32[]
	var f_best = f(x)
	var x_best = x

	for step in 0:1000
		var dx = 0.01
		for i in 0:len(x)
			var xx = x_best
			xx[i] += dx
			var cur = f(xx)
			if cur < f_best
				x_best = xx
				f_best = cur
			else
				xx[i] -= 2 * dx
				cur = f(xx)
				if cur < f_best
					x_best = xx
					f_best = cur

	return x_best



